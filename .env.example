# PuntMate NZ — required configuration (GitHub Secrets in production; a local
# .env is fine for running scripts by hand, but is never read by CI — GitHub
# Actions injects these as real secrets, see .github/workflows/generate.yml).
#
# Never commit a real .env file. This file documents names only — no values.

# --- Picks pipeline ---
ANTHROPIC_API_KEY=
ODDS_API_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# --- Instagram / Facebook (Meta Graph API) ---
# IG_USER_ID / META_PAGE_TOKEN are used for Instagram feed + Story posting.
# Facebook is NOT posted to directly anymore (Meta deprecated the
# publish_actions permission our Page token relied on) — Facebook is reported
# as "expected via linked Instagram account" instead. FB_PAGE_ID is unused
# but harmless to leave configured.
IG_USER_ID=
META_PAGE_TOKEN=
FB_PAGE_ID=

# --- Gmail preview/result emails (new — no email system existed before) ---
# GMAIL_SENDER_EMAIL / GMAIL_APP_PASSWORD authenticate an account that sends
# FROM. GMAIL_APP_PASSWORD must be a Gmail "App Password" (Google Account →
# Security → 2-Step Verification → App Passwords), not the normal account
# password. PUNTMATE_REPORT_EMAIL is where preview/result/rejection emails
# are sent TO.
GMAIL_SENDER_EMAIL=
GMAIL_APP_PASSWORD=
PUNTMATE_REPORT_EMAIL=
